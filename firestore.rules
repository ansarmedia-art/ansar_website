rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin emails list (checked against request.auth.token.email)
    function isAdminEmail() {
      return request.auth != null && 
             request.auth.token.email in [
               'd3ztudio@gmail.com',
               'ansarmedia@ansarschool.in',
               'ansarschooloffice@gmail.com'
             ];
    }
    
    // Public pages content (editable by admins only)
    match /pages/{pageId} {
      allow read: if true; // Public read
      allow create, update, delete: if isAdminEmail();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdminEmail();
      }
    }
    
    // News collection
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdminEmail();
      }
    }
    
    // Events collection
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdminEmail();
      }
    }
    
    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read: if true; // Public read for SEO meta
      allow create, update, delete: if isAdminEmail();
    }
    
    // Gallery collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdminEmail();
      }
    }
    
    // Carousel/Featured images collection
    match /carousel/{carouselId} {
      allow read: if true;
      allow create, update, delete: if isAdminEmail();
    }
    
    // Notices/Popups collection
    match /notices/{noticeId} {
      allow read: if true; // Public read for popups
      allow create, update, delete: if isAdminEmail();
    }
  }
}