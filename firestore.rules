rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: admins
    // Document ID: email address
    // Fields: role (string), email (string)
    //
    // Collection: pages
    // Fields: title (string), slug (string), subtitle (string), heroImageUrl (string), 
    //         bodyHtml (string), order (number), published (bool), createdAt/updatedAt (timestamp)
    //
    // Collection: news / events
    // Fields: title (string), excerpt/description (string), content (string), image (string),
    //         date (string), facebookUrl/instagramUrl/youtubeUrl (string), published (bool)
    //
    // Collection: gallery / carousel / notices
    // Fields: title, imageUrl, message, linkUrl, order, active/published (all strictly typed)
    //
    // Collection: settings
    // Fields: schoolName, email, phone, address, logoUrl, siteDescription
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an admin
    // Admins must be authenticated AND exist in the 'admins' collection 
    // OR match the hardcoded initialization emails.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        (request.auth.token.email != null && request.auth.token.email in ['d3ztudio@gmail.com', 'ansarmedia@ansarschool.in', 'ansarschooloffice@gmail.com']) ||
        (request.auth.token.email != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    // Validate string length to prevent 1MB DoS attacks
    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    // Validate optional string (if present, must be string and within length)
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // Enforce strict schema by ensuring no extraneous fields are added
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validate that a field is a timestamp (if present)
    function isOptionalTimestamp(field) {
      return !(field in request.resource.data) || request.resource.data[field] is timestamp;
    }

    // Validate URL format (must start with https:// or http://)
    function isValidUrl(field) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == "" ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() < 1000 &&
             (request.resource.data[field].matches("^https?://.*") || request.resource.data[field].matches("^/.*")));
    }

    // Validate URL List (for Event image carousels)
    function isOptionalUrlList(field, maxListSize) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is list && request.resource.data[field].size() <= maxListSize);
    }

    // Validate basic date string format (YYYY-MM-DD)
    function isValidDateString(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == "" ||
             (request.resource.data[field] is string && request.resource.data[field].size() <= 50);
    }

    function isOptionalBool(field) {
      return !(field in request.resource.data) || request.resource.data[field] is bool;
    }

    function isOptionalNumber(field) {
      return !(field in request.resource.data) || request.resource.data[field] is number;
    }

    // Protect immutable fields like createdAt
    function isImmutable(field) {
      return !(field in resource.data) || 
             (field in request.resource.data && request.resource.data[field] == resource.data[field]);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidPage() {
      return hasOnlyAllowedFields(['title', 'slug', 'subtitle', 'category', 'heroImageUrl', 'bodyHtml', 'virtualTourUrl', 'virtualTourText', 'order', 'published', 'href', 'metaDescription', 'keywords', 'createdAt', 'updatedAt']) &&
             isValidStringLength('title', 1, 200) &&
             isValidStringLength('slug', 1, 200) &&
             isValidOptionalString('subtitle', 0, 1000) &&
             isValidOptionalString('category', 0, 100) &&
             isValidOptionalString('bodyHtml', 0, 100000) && // Limit HTML body to ~100KB
             isValidUrl('heroImageUrl') &&
             isValidOptionalString('virtualTourUrl', 0, 1000) &&
             isValidOptionalString('virtualTourText', 0, 200) &&
             isValidOptionalString('href', 0, 500) &&
             isValidOptionalString('metaDescription', 0, 1000) &&
             isValidOptionalString('keywords', 0, 500) &&
             isOptionalNumber('order') &&
             isOptionalBool('published') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidNews() {
      return hasOnlyAllowedFields(['title', 'excerpt', 'content', 'image', 'date', 'facebookUrl', 'instagramUrl', 'youtubeUrl', 'published', 'author', 'createdAt', 'updatedAt']) &&
             isValidStringLength('title', 1, 200) &&
             isValidOptionalString('excerpt', 0, 1500) &&
             isValidOptionalString('content', 0, 50000) &&
             isValidDateString('date') &&
             isValidUrl('image') &&
             isValidUrl('facebookUrl') &&
             isValidUrl('instagramUrl') &&
             isValidUrl('youtubeUrl') &&
             isOptionalBool('published') &&
             isValidOptionalString('author', 0, 100) &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidEvent() {
      return hasOnlyAllowedFields(['title', 'description', 'location', 'time', 'image', 'imageUrls', 'date', 'facebookUrl', 'instagramUrl', 'youtubeUrl', 'published', 'createdAt', 'updatedAt']) &&
             isValidStringLength('title', 1, 200) &&
             isValidOptionalString('description', 0, 10000) &&
             isValidOptionalString('location', 0, 300) &&
             isValidOptionalString('time', 0, 100) &&
             isValidDateString('date') &&
             isValidUrl('image') &&
             isOptionalUrlList('imageUrls', 20) &&
             isValidUrl('facebookUrl') &&
             isValidUrl('instagramUrl') &&
             isValidUrl('youtubeUrl') &&
             isOptionalBool('published') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidUpdate() {
      return hasOnlyAllowedFields(['category', 'title', 'description', 'imageUrl', 'imageUrls', 'coverImageUrl', 'eventImages', 'date', 'facebookUrl', 'instagramUrl', 'youtubeUrl', 'published', 'createdAt', 'updatedAt']) &&
             request.resource.data.category in ['News', 'Events'] &&
             isValidStringLength('title', 1, 200) &&
             isValidOptionalString('description', 0, 50000) &&
             isValidUrl('imageUrl') &&
             isOptionalUrlList('imageUrls', 20) &&
             isValidUrl('coverImageUrl') &&
             isOptionalUrlList('eventImages', 20) &&
             isValidDateString('date') &&
             isValidUrl('facebookUrl') &&
             isValidUrl('instagramUrl') &&
             isValidUrl('youtubeUrl') &&
             isOptionalBool('published') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidGalleryItem() {
      return hasOnlyAllowedFields(['title', 'caption', 'imageUrl', 'category', 'order', 'published', 'createdAt', 'updatedAt']) &&
             isValidStringLength('title', 1, 200) &&
             isValidOptionalString('caption', 0, 1000) &&
             isValidOptionalString('category', 0, 100) &&
             isValidUrl('imageUrl') &&
             isOptionalNumber('order') &&
             isOptionalBool('published') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidCarouselItem() {
      return hasOnlyAllowedFields(['title', 'description', 'imageUrl', 'linkUrl', 'order', 'active', 'createdAt', 'updatedAt']) &&
             isValidStringLength('title', 1, 200) &&
             isValidOptionalString('description', 0, 1000) &&
             isValidUrl('imageUrl') &&
             isValidUrl('linkUrl') &&
             isOptionalNumber('order') &&
             isOptionalBool('active') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidNotice() {
      return hasOnlyAllowedFields(['title', 'message', 'imageUrl', 'buttonText', 'buttonUrl', 'duration', 'active', 'createdAt', 'updatedAt']) &&
             isValidOptionalString('title', 0, 200) &&
             isValidOptionalString('message', 0, 2000) &&
             isValidOptionalString('imageUrl', 0, 1000) &&
             isValidOptionalString('buttonText', 0, 100) &&
             isValidOptionalString('buttonUrl', 0, 1000) &&
             isOptionalNumber('duration') &&
             isOptionalBool('active') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidSettings() {
      // 'twitterUrl' remains allowed to prevent schema validation failures on legacy documents
      return hasOnlyAllowedFields([
               'schoolName', 'email', 'phone', 'address', 'logoUrl', 
               'siteDescription', 'siteKeywords', 'heroTitle', 
               'facebookUrl', 'instagramUrl', 'youtubeUrl', 'twitterUrl', 'whatsappChannelUrl', 
               'premisesImages', 'kgImages', 'visionText', 'missionText', 'feeStructurePdfUrl',
               'sustainabilityTitle', 'sustainabilityDesc', 'sustainabilityLogoUrl', 
               'createdAt', 'updatedAt'
             ]) &&
             isOptionalUrlList('premisesImages', 50) &&
             isOptionalUrlList('kgImages', 50) &&
             isValidOptionalString('visionText', 0, 5000) &&
             isValidOptionalString('missionText', 0, 5000) &&
             isValidOptionalString('sustainabilityTitle', 0, 500) &&
             isValidOptionalString('sustainabilityDesc', 0, 5000) &&
             isValidOptionalString('sustainabilityLogoUrl', 0, 1000) &&
             isValidOptionalString('feeStructurePdfUrl', 0, 1000) &&
             isValidOptionalString('schoolName', 0, 200) &&
             isValidOptionalString('email', 0, 200) &&
             isValidOptionalString('phone', 0, 50) &&
             isValidOptionalString('address', 0, 500) &&
             isValidOptionalString('siteDescription', 0, 1000) &&
             isValidOptionalString('siteKeywords', 0, 1000) &&
             isValidOptionalString('heroTitle', 0, 500) &&
             isValidUrl('logoUrl') &&
             isValidUrl('facebookUrl') &&
             isValidUrl('instagramUrl') &&
             isValidUrl('youtubeUrl') &&
             isValidUrl('twitterUrl') &&
             isValidUrl('whatsappChannelUrl') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidNavigation() {
      return hasOnlyAllowedFields(['label', 'href', 'slug', 'type', 'order', 'createdAt', 'updatedAt']) &&
             isValidStringLength('label', 1, 100) &&
             isValidOptionalString('href', 0, 500) &&
             isValidOptionalString('slug', 0, 200) &&
             isValidOptionalString('type', 0, 50) &&
             isOptionalNumber('order') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidSport() {
      return hasOnlyAllowedFields(['title', 'content', 'imageUrl', 'published', 'createdAt', 'updatedAt']) &&
             isValidStringLength('title', 1, 200) &&
             isValidOptionalString('content', 0, 50000) &&
             isValidUrl('imageUrl') &&
             isOptionalBool('published') &&
             isOptionalTimestamp('createdAt') &&
             isOptionalTimestamp('updatedAt');
    }

    function isValidAnsarTimes() {
        return hasOnlyAllowedFields(['title', 'fileUrl', 'coverImageUrl', 'date', 'published', 'createdAt', 'updatedAt']) &&
               isValidStringLength('title', 1, 200) &&
               isValidUrl('fileUrl') &&
               isValidUrl('coverImageUrl') &&
               isValidDateString('date') &&
               isOptionalBool('published') &&
               isOptionalTimestamp('createdAt') &&
               isOptionalTimestamp('updatedAt');
    }

    function isValidLeadership() {
        return hasOnlyAllowedFields(['name', 'role', 'qualification', 'imageUrl', 'order', 'published', 'createdAt', 'updatedAt']) &&
               isValidStringLength('name', 1, 200) &&
               isValidStringLength('role', 1, 200) &&
               isValidOptionalString('qualification', 0, 500) &&
               isValidOptionalString('imageUrl', 0, 1000) &&
               isOptionalNumber('order') &&
               isOptionalBool('published') &&
               isOptionalTimestamp('createdAt') &&
               isOptionalTimestamp('updatedAt');
    }

    function isValidAchievement() {
        return hasOnlyAllowedFields(['title', 'description', 'imageUrl', 'date', 'studentName', 'order', 'published', 'createdAt', 'updatedAt']) &&
               isValidStringLength('title', 1, 200) &&
               isValidOptionalString('description', 0, 10000) &&
               isValidUrl('imageUrl') &&
               isValidDateString('date') &&
               isValidOptionalString('studentName', 0, 500) &&
               isOptionalNumber('order') &&
               isOptionalBool('published') &&
               isOptionalTimestamp('createdAt') &&
               isOptionalTimestamp('updatedAt');
    }

    function isValidPublicDisclosure() {
        return hasOnlyAllowedFields(['title', 'documentUrl', 'fileUrl', 'createdAt', 'updatedAt']) &&
               isValidOptionalString('title', 0, 300) &&
               isValidOptionalString('documentUrl', 0, 1000) &&
               isValidOptionalString('fileUrl', 0, 1000) &&
               isOptionalTimestamp('createdAt') &&
               isOptionalTimestamp('updatedAt');
    }

    function isValidUserTracking() {
        return hasOnlyAllowedFields(['email', 'createdAt', 'lastLogin']) &&
               isValidOptionalString('email', 0, 200) &&
               isValidOptionalString('createdAt', 0, 100) &&
               isOptionalTimestamp('lastLogin');
    }

    // ===============================================================
    // Access Rules
    // ===============================================================

    // Security rules for the Administrators list
    // Strictly restricted to prevent privilege escalation
    match /admins/{emailId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Must be managed directly via Firebase Console
    }

    // Public Pages
    match /pages/{pageSlug} {
      allow read: if true;
      allow create: if isAdmin() && isValidPage();
      allow update: if isAdmin() && isValidPage() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // News Articles
    match /news/{newsId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNews();
      allow update: if isAdmin() && isValidNews() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Events
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvent();
      allow update: if isAdmin() && isValidEvent() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Unified News/Events Collection
    match /updates/{updateId} {
      allow read: if true;
      allow create: if isAdmin() && isValidUpdate();
      allow update: if isAdmin() && isValidUpdate() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Photo Gallery
    match /gallery/{galleryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGalleryItem();
      allow update: if isAdmin() && isValidGalleryItem() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Carousel Images
    match /carousel/{carouselId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCarouselItem();
      allow update: if isAdmin() && isValidCarouselItem() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Notices & Popups
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNotice();
      allow update: if isAdmin() && isValidNotice() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Site Navigation links
    match /navigation/{navId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNavigation();
      allow update: if isAdmin() && isValidNavigation() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Global Settings (General, SEO)
    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSettings();
      allow update: if isAdmin() && isValidSettings() && isImmutable('createdAt');
      allow delete: if false; // Settings documents should not be deleted, only updated
    }

    // Sports Page Content
    match /sports/{sportId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSport();
      allow update: if isAdmin() && isValidSport() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Ansar Times (PDFs)
    match /ansarTimes/{timeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAnsarTimes();
      allow update: if isAdmin() && isValidAnsarTimes() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Achievements
    match /achievements/{achievementId} {
      allow read: if true;
      allow create: if isAdmin() && isValidAchievement();
      allow update: if isAdmin() && isValidAchievement() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    // Leadership
    match /leadership/{leaderId} {
      allow read: if true;
      allow create: if isAdmin() && isValidLeadership();
      allow update: if isAdmin() && isValidLeadership() && isImmutable('createdAt');
      allow delete: if isAdmin();
    }

    match /publicDisclosure/{docId} {
        allow read: if true;
        allow create: if isAdmin() && isValidPublicDisclosure();
        allow update: if isAdmin() && isValidPublicDisclosure() && isImmutable('createdAt');
        allow delete: if isAdmin();
    }

    // User Metrics & Activity Tracking
    match /users/{userId} {
        allow read: if isAdmin();
        allow create, update: if isAuthenticated() && request.auth.uid == userId && isValidUserTracking();
        allow delete: if isAdmin();
    }
  }
}