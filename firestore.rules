rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin users collection
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == adminId;
      allow create: if false; // Only created by Firebase functions
    }
    
    // Public pages content (editable by admins only)
    match /pages/{pageId} {
      allow read: if true; // Public read
      allow create, update, delete: if isAdmin();
      
      // Nested images subcollection for each page
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }
    
    // News collection
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }
    
    // Events collection
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }
    
    // Settings collection (admin only)
    match /settings/{settingId} {
      allow read: if true; // Public read for SEO meta
      allow create, update, delete: if isAdmin();
    }
    
    // Gallery collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      
      match /images/{imageId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }
  }
  
  // Helper function to check if user is admin
  function isAdmin() {
    return request.auth != null && 
           get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
  }
}
